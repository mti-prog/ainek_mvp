# Ainek Environment Variables
# Copy to .env and fill in your values

# Supabase (for inventory database)
SUPABASE_URL=
SUPABASE_KEY=

# Camera
CAMERA_INDEX=0
CAMERA_FPS=30

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173

# Model
SD_MODEL_ID=runwayml/stable-diffusion-v1-5
USE_GPU=true
